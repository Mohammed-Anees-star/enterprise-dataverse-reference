# ============================================================
# Enterprise Ticketing API — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# In production, values come from Azure Key Vault via Managed Identity.
# ============================================================

# ============================================================
# Azure AD / Entra ID
# ============================================================
AZUREAD__INSTANCE=https://login.microsoftonline.com/
AZUREAD__TENANTID=your-tenant-id-here
AZUREAD__CLIENTID=your-api-application-client-id-here
AZUREAD__AUDIENCE=api://your-api-application-client-id-here

# ============================================================
# Dataverse
# ============================================================
DATAVERSE__URL=https://yourorgname.crm.dynamics.com
DATAVERSE__TENANTID=your-tenant-id-here
DATAVERSE__CLIENTID=your-dataverse-app-registration-client-id
DATAVERSE__CLIENTSECRET=your-client-secret-here
DATAVERSE__MAXRETRYCOUNT=3
DATAVERSE__TIMEOUTSECONDS=30

# ============================================================
# Azure Service Bus
# ============================================================
SERVICEBUS__CONNECTIONSTRING=Endpoint=sb://yournamespace.servicebus.windows.net/;SharedAccessKeyName=...
SERVICEBUS__TICKETEVENTSQUEUENAME=ticket-events
SERVICEBUS__NOTIFICATIONSQUEUENAME=ticket-notifications

# ============================================================
# Application Insights
# ============================================================
APPLICATIONINSIGHTS__CONNECTIONSTRING=InstrumentationKey=...;IngestionEndpoint=...

# ============================================================
# Azure Key Vault (optional for local dev, required for production)
# ============================================================
KEYVAULT__VAULTURI=https://your-keyvault-name.vault.azure.net/

# ============================================================
# ASP.NET Core
# ============================================================
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080
