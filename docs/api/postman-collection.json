{
  "info": {
    "name": "Enterprise Ticketing API",
    "description": "Complete API collection for the Enterprise Ticketing reference implementation.\n\nSetup:\n1. Set environment variables (see Environments section)\n2. Run 'Get Token' request first\n3. Token is auto-saved to {{access_token}} variable\n4. All other requests use Bearer token automatically",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://localhost:5001" },
    { "key": "tenantId", "value": "YOUR_TENANT_ID" },
    { "key": "clientId", "value": "YOUR_API_CLIENT_ID" },
    { "key": "clientSecret", "value": "YOUR_CLIENT_SECRET" },
    { "key": "scope", "value": "api://YOUR_API_CLIENT_ID/.default" },
    { "key": "access_token", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Get Token (Client Credentials)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var json = pm.response.json();",
                "pm.collectionVariables.set('access_token', json.access_token);",
                "pm.test('Token acquired', () => pm.response.to.have.status(200));",
                "console.log('Token expires in:', json.expires_in, 'seconds');"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": "https://login.microsoftonline.com/{{tenantId}}/oauth2/v2.0/token",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "client_credentials" },
                { "key": "client_id", "value": "{{clientId}}" },
                { "key": "client_secret", "value": "{{clientSecret}}" },
                { "key": "scope", "value": "{{scope}}" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Tickets v1",
      "item": [
        {
          "name": "Create Ticket",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                "pm.test('Has ticket ID', () => pm.expect(pm.response.json().id).to.be.a('string'));",
                "pm.collectionVariables.set('ticketId', pm.response.json().id);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/tickets",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Production database connectivity issue\",\n  \"description\": \"Users experiencing intermittent connection failures since 14:30 UTC.\",\n  \"priority\": \"Critical\",\n  \"category\": \"TechnicalSupport\",\n  \"customerId\": \"3fa85f64-5717-4562-b3fc-2c963f66afa6\"\n}"
            }
          }
        },
        {
          "name": "Get Ticket by ID",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                "pm.test('Has ticket number', () => pm.expect(pm.response.json().ticketNumber).to.match(/^TKT-/));"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/tickets/{{ticketId}}"
          }
        },
        {
          "name": "Get Tickets (paginated)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets?pageNumber=1&pageSize=20&status=Open&sortDesc=true",
              "query": [
                { "key": "pageNumber", "value": "1" },
                { "key": "pageSize", "value": "20" },
                { "key": "status", "value": "Open" },
                { "key": "sortDesc", "value": "true" }
              ]
            }
          }
        },
        {
          "name": "Update Ticket",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/tickets/{{ticketId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated: Database connectivity issue — Root cause identified\",\n  \"description\": \"Root cause: connection pool exhaustion. Fix in progress.\",\n  \"priority\": \"High\",\n  \"category\": \"TechnicalSupport\"\n}"
            }
          }
        },
        {
          "name": "Escalate Ticket",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/tickets/{{ticketId}}/escalate",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"SLA breach — ticket open for 4 hours without resolution\"\n}"
            }
          }
        },
        {
          "name": "Close Ticket",
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["pm.test('Status 204 No Content', () => pm.response.to.have.status(204));"]
            }
          }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/tickets/{{ticketId}}/close"
          }
        }
      ]
    },
    {
      "name": "Health Checks",
      "item": [
        {
          "name": "Liveness",
          "request": { "method": "GET", "url": "{{baseUrl}}/health/live" }
        },
        {
          "name": "Readiness",
          "request": { "method": "GET", "url": "{{baseUrl}}/health/ready" }
        },
        {
          "name": "Full Health",
          "request": { "method": "GET", "url": "{{baseUrl}}/health" }
        }
      ]
    }
  ]
}
